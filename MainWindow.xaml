<Window x:Class="ExpenseTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}"
        Height="650"
        Width="1080"
        MinHeight="520"
        MinWidth="820"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="16"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Direction="270" Opacity="0.08"
                                  ShadowDepth="4" Color="#1F2937"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App Logo + Title -->
                <StackPanel>
                    <Border Width="52" Height="52"
                            HorizontalAlignment="Right"
                            Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="16"
                            Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" Direction="270" Opacity="0.4"
                                              ShadowDepth="4" Color="#7C3AED"/>
                        </Border.Effect>
                        <Image Source="Images/logo.png"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{DynamicResource AppTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="{DynamicResource AppSubtitle}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="13"
                               Margin="0,6,0,28"/>
                    
                    <!-- Clock -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="16"
                            Margin="0,0,0,28">
                        <TextBlock Text="{Binding ClockViewModel.CurrentTime, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   FontFamily="Consolas"/>
                    </Border>
                </StackPanel>

                <!-- Nav Buttons -->
                <StackPanel Grid.Row="1">
                    <Button x:Name="TransactionsButton"
                            Content="{DynamicResource TransactionsNavText}"
                            Click="TransactionsButton_Click"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,0,8"/>
                    <Button x:Name="StatsButton"
                            Content="{DynamicResource StatsNavText}"
                            Click="StatsButton_Click"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,0,8"/>
                    <Button x:Name="AccountsButton"
                            Content="{DynamicResource AccountsNavText}"
                            Click="AccountsButton_Click"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,0,8"/>
                    <Button x:Name="SettingsButton"
                            Content="{DynamicResource SettingsNavText}"
                            Click="SettingsButton_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>

                <!-- Bottom: Language, Theme, Delete All -->
                <StackPanel Grid.Row="2">

                    <!-- Language Toggle -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="16"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource LanguageLabel}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource LanguageOptionText}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="12" Margin="0,3,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding IsEnglish, Mode=TwoWay}"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Theme Toggle -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="16"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource ThemeLabel}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource ThemeOptionText}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="12" Margin="0,3,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding IsDarkMode, Mode=TwoWay}"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Delete All Data -->
                    <Button Content="{DynamicResource DeleteAllDataText}"
                            Click="DeleteAllDataButton_Click"
                            Cursor="Hand"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Padding="16,12"
                            BorderThickness="0"
                            Background="#3D1A1A"
                            Foreground="#EF4444">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="14"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#4D2A2A"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <ContentControl x:Name="MainContent"
                        Grid.Column="1"
                        Margin="0,16,16,16"/>
    </Grid>
</Window>
