<Window x:Class="ExpenseTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}"
        Height="650"
        Width="1080"
        MinHeight="520"
        MinWidth="820"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="16"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="46"
                            Height="46"
                            HorizontalAlignment="Right"
                            Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="14"
                            Margin="0,0,0,14">
                        <TextBlock Text="₪"
                                   Foreground="{DynamicResource OnPrimaryBrush}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="{DynamicResource AppTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="21"
                               FontWeight="Bold"/>

                    <TextBlock Text="{DynamicResource AppSubtitle}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="13"
                               Margin="0,6,0,26"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="TransactionsButton"
                            Content="{DynamicResource TransactionsNavText}"
                            Click="TransactionsButton_Click"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,0,8"/>

                    <Button x:Name="StatsButton"
                            Content="{DynamicResource StatsNavText}"
                            Click="StatsButton_Click"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,0,8"/>

                    <Button x:Name="AccountsButton"
                            Content="{DynamicResource AccountsNavText}"
                            Click="AccountsButton_Click"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,0,8"/>

                    <Button x:Name="SettingsButton"
                            Content="{DynamicResource SettingsNavText}"
                            Click="SettingsButton_Click"
                            Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14"
                            Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{DynamicResource LanguageLabel}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource LanguageOptionText}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="12"
                                           Margin="0,3,0,0"/>
                            </StackPanel>

                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding IsEnglish, Mode=TwoWay}"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="{DynamicResource ThemeLabel}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource ThemeOptionText}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           FontSize="12"
                                           Margin="0,3,0,0"/>
                            </StackPanel>

                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding IsDarkMode, Mode=TwoWay}"
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl x:Name="MainContent"
                        Grid.Column="1"
                        Margin="0,16,16,16"/>
    </Grid>
</Window>
