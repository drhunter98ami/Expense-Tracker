<Window x:Class="ExpenseTracker.Views.CategoryTransactionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:ExpenseTracker.Converters"
        Title="{Binding CategoryName}"
        Width="900"
        Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <converters:EnglishNumberConverter x:Key="EnglishNumberConverter"/>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Style x:Key="TabPillButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TransactionItemTemplate">
            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="16"
                    Margin="0,0,0,8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" Direction="270" Opacity="0.07"
                                      ShadowDepth="2" Color="#0F172A"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Description}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Text="{Binding CategoryName}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="13"/>
                            <TextBlock Text="  •  "
                                       Foreground="{DynamicResource BorderBrush}"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding AccountName}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock Text="🕐"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding TimeText}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            CornerRadius="10"
                            Padding="12,8"
                            VerticalAlignment="Center"
                            Margin="20,0,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1A2E1A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIncome}" Value="False">
                                        <Setter Property="Background" Value="#2E1A1A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsTransfer}" Value="True">
                                        <Setter Property="Background" Value="#1A1A1A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding FormattedAmount}"
                                   FontSize="16"
                                   FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#10B981"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsIncome}" Value="False">
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsTransfer}" Value="True">
                                            <Setter Property="Foreground" Value="#F5F5F5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="24,24,24,16">
            <TextBlock Text="{Binding CategoryName}"
                       Foreground="{DynamicResource TextBrush}"
                       FontSize="24"
                       FontWeight="Bold"/>
            <TextBlock Text="Transactions"
                       Foreground="{DynamicResource MutedTextBrush}"
                       FontSize="14"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Subcategory Selection -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="20"
                Margin="24,0,24,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Subcategories"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,12"/>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding SubCategories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,8,8"
                                    Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Padding="12,8">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{Binding Color, Converter={StaticResource ColorToBrushConverter}}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text=" • "
                                               Margin="4,0,0,0"/>
                                    <TextBlock Text="{Binding Percentage, StringFormat={}{0:N1}%}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text=" • "
                                               Margin="4,0,0,0"/>
                                    <TextBlock Text="{Binding Amount, StringFormat={}{0:N2} ل.س}"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- Transactions List -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Margin="24,0,24,16">
            <ItemsControl ItemsSource="{Binding Transactions}"
                          ItemTemplate="{StaticResource TransactionItemTemplate}">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Transactions.Count}" Value="0">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ItemsControl">
                                            <TextBlock Text="No transactions found"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="16"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,40,0,0"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
            </ItemsControl>
        </ScrollViewer>

        <!-- Close Button -->
        <Button Grid.Row="3"
                Content="Close"
                Command="{Binding CloseCommand}"
                Style="{StaticResource TabPillButtonStyle}"
                HorizontalAlignment="Center"
                Margin="24,0,24,24"
                Padding="40,12"/>
    </Grid>
</Window>
