<UserControl x:Class="ExpenseTracker.Views.StatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="28"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tab Buttons -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Button Content="{DynamicResource IncomeTabText}"
                            Command="{Binding SelectIncomeTabCommand}"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIncomeTab}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource ExpenseTabText}"
                            Command="{Binding SelectExpenseTabCommand}"
                            Margin="8,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpenseTab}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Pie Chart -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24">
                    <Grid>
                        <lvc:PieChart LegendLocation="Bottom"
                                      Series="{Binding IncomePieSeries}"
                                      x:Name="IncomeChart"
                                      Margin="0,0,0,20">
                            <lvc:PieChart.DataTooltip>
                                <lvc:DefaultTooltip SelectionMode="OnlySender"/>
                            </lvc:PieChart.DataTooltip>
                        </lvc:PieChart>

                        <lvc:PieChart LegendLocation="Bottom"
                                      Series="{Binding ExpensePieSeries}"
                                      x:Name="ExpenseChart"
                                      Margin="0,0,0,20"
                                      Visibility="Collapsed">
                            <lvc:PieChart.DataTooltip>
                                <lvc:DefaultTooltip SelectionMode="OnlySender"/>
                            </lvc:PieChart.DataTooltip>
                        </lvc:PieChart>

                        <TextBlock Text="{DynamicResource NoDataText}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   x:Name="NoDataText"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
