<UserControl x:Class="ExpenseTracker.Views.StatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="28"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Period Buttons -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Button Content="{DynamicResource WeeklyPeriodText}"
                            Command="{Binding SelectWeeklyPeriodCommand}"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWeeklyPeriod}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource MonthlyPeriodText}"
                            Command="{Binding SelectMonthlyPeriodCommand}"
                            Margin="4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMonthlyPeriod}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource AnnuallyPeriodText}"
                            Command="{Binding SelectAnnuallyPeriodCommand}"
                            Margin="4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAnnuallyPeriod}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource PeriodPeriodText}"
                            Command="{Binding SelectPeriodPeriodCommand}"
                            Margin="4,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPeriodPeriod}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Navigation Controls -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <!-- Weekly Navigation -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsWeeklyPeriod, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,8,0">
                        <Button Content="◀" Command="{Binding PreviousWeekCommand}" Width="32" Height="32" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding WeekRangeText}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
                        <Button Content="▶" Command="{Binding NextWeekCommand}" Width="32" Height="32" Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource CurrentText}" Command="{Binding GoToCurrentWeekCommand}" Margin="0,0,0,0"/>
                    </StackPanel>

                    <!-- Monthly Navigation -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsMonthlyPeriod, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,8,0">
                        <Button Content="◀" Command="{Binding PreviousMonthCommand}" Width="32" Height="32" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding MonthYearText}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
                        <Button Content="▶" Command="{Binding NextMonthCommand}" Width="32" Height="32" Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource CurrentText}" Command="{Binding GoToCurrentMonthCommand}" Margin="0,0,0,0"/>
                    </StackPanel>

                    <!-- Yearly Navigation -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsAnnuallyPeriod, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,8,0">
                        <Button Content="◀" Command="{Binding PreviousYearCommand}" Width="32" Height="32" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding YearText}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14"/>
                        <Button Content="▶" Command="{Binding NextYearCommand}" Width="32" Height="32" Margin="0,0,8,0"/>
                        <Button Content="{DynamicResource CurrentText}" Command="{Binding GoToCurrentYearCommand}" Margin="0,0,0,0"/>
                    </StackPanel>

                    <!-- Period Navigation -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsPeriodPeriod, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{DynamicResource FromText}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <DatePicker SelectedDate="{Binding PeriodStartDate}" Width="120" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource ToText}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <DatePicker SelectedDate="{Binding PeriodEndDate}" Width="120" Margin="0,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Tab Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Button Content="{DynamicResource IncomeTabText}"
                            Command="{Binding SelectIncomeTabCommand}"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIncomeTab}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource ExpenseTabText}"
                            Command="{Binding SelectExpenseTabCommand}"
                            Margin="8,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpenseTab}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Pie Chart -->
                <Border Grid.Row="3"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24">
                    <Grid>
                        <lvc:PieChart LegendLocation="Bottom"
                                      Series="{Binding IncomePieSeries}"
                                      x:Name="IncomeChart"
                                      Margin="0,0,0,20">
                            <lvc:PieChart.DataTooltip>
                                <lvc:DefaultTooltip SelectionMode="OnlySender"/>
                            </lvc:PieChart.DataTooltip>
                        </lvc:PieChart>

                        <lvc:PieChart LegendLocation="Bottom"
                                      Series="{Binding ExpensePieSeries}"
                                      x:Name="ExpenseChart"
                                      Margin="0,0,0,20"
                                      Visibility="Collapsed">
                            <lvc:PieChart.DataTooltip>
                                <lvc:DefaultTooltip SelectionMode="OnlySender"/>
                            </lvc:PieChart.DataTooltip>
                        </lvc:PieChart>

                        <TextBlock Text="{DynamicResource NoDataText}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   x:Name="NoDataText"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
