<UserControl x:Class="ExpenseTracker.Views.StatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">
    <UserControl.Resources>
        <Style x:Key="TransparentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="28"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Period Buttons -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Button Content="{DynamicResource WeeklyPeriodText}"
                            Command="{Binding SelectWeeklyPeriodCommand}"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWeeklyPeriod}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource MonthlyPeriodText}"
                            Command="{Binding SelectMonthlyPeriodCommand}"
                            Margin="4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMonthlyPeriod}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource AnnuallyPeriodText}"
                            Command="{Binding SelectAnnuallyPeriodCommand}"
                            Margin="4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAnnuallyPeriod}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource PeriodPeriodText}"
                            Command="{Binding SelectPeriodPeriodCommand}"
                            Margin="4,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPeriodPeriod}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Navigation Controls -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <!-- Weekly Navigation -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsWeeklyPeriod, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,8,0">
                        <Button Command="{Binding PreviousWeekCommand}" Width="36" Height="36" Margin="0,0,8,0" FontSize="18" FontWeight="Bold" Content="▶">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock Text="{Binding WeekRangeText}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextBrush}"/>
                        <Button Command="{Binding NextWeekCommand}" Width="36" Height="36" Margin="0,0,8,0" FontSize="18" FontWeight="Bold" Content="◀">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource CurrentText}" Command="{Binding GoToCurrentWeekCommand}" Margin="0,0,0,0" Padding="12,6">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Monthly Navigation -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsMonthlyPeriod, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,8,0">
                        <Button Command="{Binding PreviousMonthCommand}" Width="36" Height="36" Margin="0,0,8,0" FontSize="18" FontWeight="Bold" Content="▶">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock Text="{Binding MonthYearText}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextBrush}"/>
                        <Button Command="{Binding NextMonthCommand}" Width="36" Height="36" Margin="0,0,8,0" FontSize="18" FontWeight="Bold" Content="◀">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource CurrentText}" Command="{Binding GoToCurrentMonthCommand}" Margin="0,0,0,0" Padding="12,6">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Yearly Navigation -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsAnnuallyPeriod, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,8,0">
                        <Button Command="{Binding PreviousYearCommand}" Width="36" Height="36" Margin="0,0,8,0" FontSize="18" FontWeight="Bold" Content="▶">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock Text="{Binding YearText}" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource TextBrush}"/>
                        <Button Command="{Binding NextYearCommand}" Width="36" Height="36" Margin="0,0,8,0" FontSize="18" FontWeight="Bold" Content="◀">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{DynamicResource CurrentText}" Command="{Binding GoToCurrentYearCommand}" Margin="0,0,0,0" Padding="12,6">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Period Navigation -->
                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsPeriodPeriod, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{DynamicResource FromText}" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="Medium" Foreground="{DynamicResource TextBrush}"/>
                        <DatePicker SelectedDate="{Binding PeriodStartDate}" Width="120" Margin="0,0,8,0"/>
                        <TextBlock Text="{DynamicResource ToText}" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="Medium" Foreground="{DynamicResource TextBrush}"/>
                        <DatePicker SelectedDate="{Binding PeriodEndDate}" Width="120" Margin="0,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Tab Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Button Content="{DynamicResource IncomeTabText}"
                            Command="{Binding SelectIncomeTabCommand}"
                            Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsIncomeTab}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="{DynamicResource ExpenseTabText}"
                            Command="{Binding SelectExpenseTabCommand}"
                            Margin="8,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpenseTab}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Pie Chart -->
                <Border Grid.Row="3"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="24">
                    <Grid>
                        <lvc:PieChart LegendLocation="None"
                                      Series="{Binding CurrentPieSeries}"
                                      x:Name="PieChart"
                                      Margin="0,0,0,20">
                            <lvc:PieChart.DataTooltip>
                                <lvc:DefaultTooltip SelectionMode="OnlySender"/>
                            </lvc:PieChart.DataTooltip>
                        </lvc:PieChart>

                        <TextBlock Text="{DynamicResource NoDataText}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   x:Name="NoDataText"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- Legend -->
                <ItemsControl Grid.Row="4"
                              ItemsSource="{Binding CurrentLegendItems}"
                              Margin="0,16,0,0"
                              HorizontalAlignment="Center">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,4,0,4" 
                                    MaxWidth="400"
                                    Command="{Binding DataContext.ShowCategoryDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource TransparentButtonStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Color Indicator -->
                                    <Border Grid.Column="0"
                                            Width="16"
                                            Height="16"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Center"
                                            CornerRadius="4">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding Color}"/>
                                        </Border.Background>
                                    </Border>
                                    
                                    <!-- Category Name -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding CategoryName}"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    
                                    <!-- Percentage -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Percentage, StringFormat={}{0:N2}%}"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource TextBrush}"
                                               HorizontalAlignment="Center"/>
                                    
                                    <!-- Total Amount -->
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding TotalAmount, StringFormat={}{0:N2} ل.س}"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource TextBrush}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
