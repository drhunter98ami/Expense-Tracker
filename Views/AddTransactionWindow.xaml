<Window x:Class="ExpenseTracker.Views.AddTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AddTransactionDialogTitle}"
        Width="440"
        Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="DialogLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="DialogTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="11,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DialogComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>

        <Style x:Key="DialogDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Padding" Value="9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource AppBackgroundBrush}"
            Padding="22">
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="{DynamicResource AddTransactionDialogTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <Border Width="52"
                            Height="4"
                            HorizontalAlignment="Right"
                            Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="2"
                            Margin="0,10,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="نوع المعاملة" Style="{StaticResource DialogLabelStyle}"/>
                        <ComboBox x:Name="TransactionTypeComboBox"
                                  Style="{StaticResource DialogComboBoxStyle}"
                                  SelectionChanged="TransactionTypeComboBox_SelectionChanged">
                            <ComboBoxItem Content="دخل" Tag="Income"/>
                            <ComboBoxItem Content="مصروف" Tag="Expense"/>
                            <ComboBoxItem Content="تحويل" Tag="Transfer"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,13,0,0">
                        <TextBlock Text="التاريخ والوقت" Style="{StaticResource DialogLabelStyle}"/>
                        <StackPanel Orientation="Horizontal">
                            <DatePicker x:Name="TransactionDatePicker" Style="{StaticResource DialogDatePickerStyle}" Width="200"/>
                            <TextBox x:Name="TimeTextBox" 
                                     Style="{StaticResource DialogTextBoxStyle}" 
                                     Width="120" 
                                     Margin="10,0,0,0"
                                     Text="00:00"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,13,0,0">
                        <TextBlock Text="المبلغ" Style="{StaticResource DialogLabelStyle}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="AmountTextBox" Style="{StaticResource NumberTextBoxStyle}" Width="200"/>
                            <ComboBox x:Name="CurrencyComboBox" 
                                      Style="{StaticResource DialogComboBoxStyle}" 
                                      Width="120" 
                                      Margin="10,0,0,0">
                                <ComboBoxItem Content="ل.س" Tag="SYP"/>
                                <ComboBoxItem Content="$" Tag="USD"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,13,0,0" x:Name="AccountCategoryPanel">
                        <TextBlock Text="الحساب" Style="{StaticResource DialogLabelStyle}"/>
                        <ComboBox x:Name="AccountComboBox"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  Style="{StaticResource DialogComboBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,13,0,0" x:Name="CategoryPanel">
                        <TextBlock Text="التصنيف" Style="{StaticResource DialogLabelStyle}"/>
                        <ComboBox x:Name="CategoryComboBox"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  Style="{StaticResource DialogComboBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="5" Margin="0,13,0,0" x:Name="FromPanel" Visibility="Collapsed">
                        <TextBlock Text="من" Style="{StaticResource DialogLabelStyle}"/>
                        <ComboBox x:Name="FromComboBox"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  Style="{StaticResource DialogComboBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6" Margin="0,13,0,0" x:Name="ToPanel" Visibility="Collapsed">
                        <TextBlock Text="إلى" Style="{StaticResource DialogLabelStyle}"/>
                        <ComboBox x:Name="ToComboBox"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  Style="{StaticResource DialogComboBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="7" Margin="0,13,0,0">
                        <TextBlock Text="ملاحظة" Style="{StaticResource DialogLabelStyle}"/>
                        <TextBox x:Name="DescriptionTextBox" Style="{StaticResource DialogTextBoxStyle}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0,22,0,0">
                    <Button Content="{DynamicResource SaveText}"
                            Click="SaveButton_Click"
                            Width="100"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Content="{DynamicResource CancelText}"
                            Click="CancelButton_Click"
                            Width="100"
                            Padding="12,8"
                            Margin="10,0,0,0"
                            Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
