<UserControl x:Class="ExpenseTracker.Views.TransactionsView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:converters="clr-namespace:ExpenseTracker.Converters">

    <UserControl.Resources>

        <converters:EnglishNumberConverter x:Key="EnglishNumberConverter"/>

        <converters:GregorianDateConverter x:Key="GregorianDateConverter"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>



        <Style x:Key="TabPillButtonStyle" TargetType="Button">

            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="FontSize" Value="13"/>

            <Setter Property="FontWeight" Value="SemiBold"/>

            <Setter Property="Padding" Value="18,8"/>

            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>

            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border Background="{TemplateBinding Background}"

                                CornerRadius="20"

                                Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        </Border>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <DataTemplate x:Key="TransactionItemTemplate">

            <Border Background="{DynamicResource SurfaceBrush}"

                    BorderBrush="{DynamicResource BorderBrush}"

                    BorderThickness="1"

                    CornerRadius="16"

                    Padding="18"

                    Margin="0,0,0,10">

                <Border.Effect>

                    <DropShadowEffect BlurRadius="18" Direction="270" Opacity="0.1"

                                      ShadowDepth="3" Color="#1F2937"/>

                </Border.Effect>

                <Grid>

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="Auto"/>

                        <ColumnDefinition Width="*"/>

                        <ColumnDefinition Width="Auto"/>

                    </Grid.ColumnDefinitions>



                    <!-- Details Section (Left) -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">

                        <TextBlock Text="{Binding CategoryName}"

                                   Foreground="{DynamicResource TextBrush}"

                                   FontSize="14"

                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding SubCategoryName}"

                                   Foreground="{DynamicResource MutedTextBrush}"

                                   FontSize="12"

                                   Margin="0,2,0,0"/>

                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">

                            <TextBlock Text="🕐"

                                       FontSize="11"

                                       VerticalAlignment="Center"

                                       Margin="0,0,4,0"/>

                            <TextBlock Text="{Binding TimeText}"

                                       Foreground="{DynamicResource MutedTextBrush}"

                                       FontSize="12"/>

                        </StackPanel>

                    </StackPanel>



                    <!-- Account Section (Center) -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">

                        <TextBlock Text="{Binding Description}"

                                   Foreground="{DynamicResource MutedTextBrush}"

                                   FontSize="12"

                                   FontStyle="Italic"

                                   HorizontalAlignment="Center">

                            <TextBlock.Style>

                                <Style TargetType="TextBlock">

                                    <Setter Property="Visibility" Value="Visible"/>

                                    <Style.Triggers>

                                        <DataTrigger Binding="{Binding Description}" Value="{x:Null}">

                                            <Setter Property="Visibility" Value="Collapsed"/>

                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding Description}" Value="">

                                            <Setter Property="Visibility" Value="Collapsed"/>

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </TextBlock.Style>

                        </TextBlock>

                        <TextBlock Text="{Binding AccountName}"

                                   Foreground="{DynamicResource TextBrush}"

                                   FontSize="15"

                                   FontWeight="SemiBold"

                                   HorizontalAlignment="Center">

                            <TextBlock.Style>

                                <Style TargetType="TextBlock">

                                    <Setter Property="Margin" Value="0,4,0,0"/>

                                    <Style.Triggers>

                                        <DataTrigger Binding="{Binding Description}" Value="{x:Null}">

                                            <Setter Property="Margin" Value="0"/>

                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding Description}" Value="">

                                            <Setter Property="Margin" Value="0"/>

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </TextBlock.Style>

                        </TextBlock>

                    </StackPanel>



                    <Border Grid.Column="2"

                            CornerRadius="10"

                            Padding="12,8"

                            VerticalAlignment="Center"

                            Margin="20,0,0,0">

                        <Border.Style>

                            <Style TargetType="Border">

                                <Setter Property="Background" Value="#1A2E1A"/>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding IsIncome}" Value="False">

                                        <Setter Property="Background" Value="#2E1A1A"/>

                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding IsTransfer}" Value="True">

                                        <Setter Property="Background" Value="#1A1A1A"/>

                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>

                        </Border.Style>

                        <TextBlock Text="{Binding FormattedAmount}"

                                   FontSize="16"

                                   FontWeight="Bold">

                            <TextBlock.Style>

                                <Style TargetType="TextBlock">

                                    <Setter Property="Foreground" Value="#10B981"/>

                                    <Style.Triggers>

                                        <DataTrigger Binding="{Binding IsIncome}" Value="False">

                                            <Setter Property="Foreground" Value="#EF4444"/>

                                        </DataTrigger>

                                        <DataTrigger Binding="{Binding IsTransfer}" Value="True">

                                            <Setter Property="Foreground" Value="#F5F5F5"/>

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </TextBlock.Style>

                        </TextBlock>

                    </Border>

                </Grid>

            </Border>

        </DataTemplate>



        <Style x:Key="TransactionListViewStyle" TargetType="ListView">

            <Setter Property="Padding" Value="0"/>

            <Setter Property="Background" Value="Transparent"/>

            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>

            <Setter Property="ItemContainerStyle">

                <Setter.Value>

                    <Style TargetType="ListViewItem">

                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

                        <Setter Property="Padding" Value="0"/>

                        <Setter Property="Margin" Value="0"/>

                        <Setter Property="Background" Value="Transparent"/>

                        <Setter Property="BorderThickness" Value="0"/>

                        <Setter Property="Template">

                            <Setter.Value>

                                <ControlTemplate TargetType="ListViewItem">

                                    <ContentPresenter/>

                                </ControlTemplate>

                            </Setter.Value>

                        </Setter>

                    </Style>

                </Setter.Value>

            </Setter>

        </Style>



        <Style x:Key="GroupHeaderStyle" TargetType="{x:Type GroupItem}">

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="{x:Type GroupItem}">

                        <StackPanel Margin="0,0,0,18">

                            <Border Background="{DynamicResource GroupHeaderBrush}"

                                    BorderBrush="{DynamicResource BorderBrush}"

                                    BorderThickness="1"

                                    CornerRadius="12"

                                    Padding="16,10"

                                    Margin="0,0,0,10">

                                <TextBlock Text="{Binding Name}"

                                           Foreground="{DynamicResource PrimaryBrush}"

                                           FontSize="15"

                                           FontWeight="SemiBold"/>

                            </Border>

                            <ItemsPresenter/>

                        </StackPanel>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>



        <Style x:Key="DailyGroupHeaderStyle" TargetType="{x:Type GroupItem}">

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="{x:Type GroupItem}">

                        <StackPanel Margin="0,0,0,18">

                            <Border Background="{DynamicResource GroupHeaderBrush}"

                                    BorderBrush="{DynamicResource BorderBrush}"

                                    BorderThickness="1"

                                    CornerRadius="12"

                                    Padding="16,10"

                                    Margin="0,0,0,10">

                                <TextBlock Text="{Binding Name, Converter={StaticResource GregorianDateConverter}, ConverterParameter='dddd, dd MMMM yyyy'}"

                                           Foreground="{DynamicResource PrimaryBrush}"

                                           FontSize="15"

                                           FontWeight="SemiBold"/>

                            </Border>

                            <ItemsPresenter/>

                        </StackPanel>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </UserControl.Resources>



    <Grid Background="{DynamicResource AppBackgroundBrush}">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>



        <!-- Header -->

        <StackPanel Grid.Row="0" Margin="0,0,0,16">

            <TextBlock Text="{DynamicResource TransactionsTitle}"

                       Foreground="{DynamicResource TextBrush}"

                       FontSize="28"

                       FontWeight="Bold"/>

            <TextBlock Text="{DynamicResource TransactionsSubtitle}"

                       Foreground="{DynamicResource MutedTextBrush}"

                       FontSize="14"

                       Margin="0,6,0,0"/>

        </StackPanel>



        <!-- Summary Bar -->

        <Grid Grid.Row="1" Margin="0,0,0,14">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="8"/>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="8"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>



            <!-- Income -->

            <Border Grid.Column="0"

                    Background="#1A2E1A"

                    BorderBrush="#2D4A2D"

                    BorderThickness="1"

                    CornerRadius="16"

                    Padding="18,14">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Direction="270" Opacity="0.15"
                                      ShadowDepth="2" Color="#10B981"/>
                </Border.Effect>
                <StackPanel>

                    <TextBlock Text="{DynamicResource IncomeLabel}"

                               Foreground="#10B981"

                               FontSize="13"

                               FontWeight="SemiBold"

                               Opacity="0.85"/>

                    <TextBlock Text="{Binding TotalIncome, Converter={StaticResource EnglishNumberConverter}, ConverterParameter=N2}"

                               Foreground="#10B981"

                               FontSize="20"

                               FontWeight="Bold"

                               Margin="0,6,0,0"/>

                </StackPanel>

            </Border>



            <!-- Expenses -->

            <Border Grid.Column="2"

                    Background="#2E1A1A"

                    BorderBrush="#4A2D2D"

                    BorderThickness="1"

                    CornerRadius="16"

                    Padding="18,14">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Direction="270" Opacity="0.15"
                                      ShadowDepth="2" Color="#EF4444"/>
                </Border.Effect>
                <StackPanel>

                    <TextBlock Text="{DynamicResource ExpensesLabel}"

                               Foreground="#EF4444"

                               FontSize="13"

                               FontWeight="SemiBold"

                               Opacity="0.85"/>

                    <TextBlock Text="{Binding TotalExpenses, Converter={StaticResource EnglishNumberConverter}, ConverterParameter=N2}"

                               Foreground="#EF4444"

                               FontSize="20"

                               FontWeight="Bold"

                               Margin="0,6,0,0"/>

                </StackPanel>

            </Border>



            <!-- Net Total -->

            <Border Grid.Column="4"

                    Background="{DynamicResource ActiveBrush}"

                    BorderBrush="{DynamicResource BorderBrush}"

                    BorderThickness="1"

                    CornerRadius="16"

                    Padding="18,14">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Direction="270" Opacity="0.08"
                                      ShadowDepth="2" Color="#7C3AED"/>
                </Border.Effect>
                <StackPanel>

                    <TextBlock Text="{DynamicResource NetLabel}"

                               Foreground="{DynamicResource PrimaryBrush}"

                               FontSize="13"

                               FontWeight="SemiBold"

                               Opacity="0.85"/>

                    <TextBlock Text="{Binding NetTotal, Converter={StaticResource EnglishNumberConverter}, ConverterParameter=N2}"

                               Foreground="{DynamicResource PrimaryBrush}"

                               FontSize="20"

                               FontWeight="Bold"

                               Margin="0,6,0,0"/>

                </StackPanel>

            </Border>

        </Grid>



        <!-- Tab Buttons -->

        <Border Grid.Row="2"

                Background="{DynamicResource SurfaceBrush}"

                BorderBrush="{DynamicResource BorderBrush}"

                BorderThickness="1"

                CornerRadius="28"

                Padding="5"

                Margin="0,0,0,16">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">



                <!-- Daily Tab -->

                <Button Command="{Binding SelectDailyTabCommand}"

                        Margin="2,0">

                    <Button.Style>

                        <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsDailyTab}" Value="True">

                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>

                                    <Setter Property="Foreground" Value="White"/>

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Button.Style>

                    <TextBlock Text="{DynamicResource DailyTabText}"/>

                </Button>



                <!-- Calendar Tab -->

                <Button Command="{Binding SelectCalendarTabCommand}"

                        Margin="2,0">

                    <Button.Style>

                        <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsCalendarTab}" Value="True">

                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>

                                    <Setter Property="Foreground" Value="White"/>

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Button.Style>

                    <TextBlock Text="{DynamicResource CalendarTabText}"/>

                </Button>



                <!-- Monthly Tab -->

                <Button Command="{Binding SelectMonthlyTabCommand}"

                        Margin="2,0">

                    <Button.Style>

                        <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsMonthlyTab}" Value="True">

                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>

                                    <Setter Property="Foreground" Value="White"/>

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Button.Style>

                    <TextBlock Text="{DynamicResource MonthlyTabText}"/>

                </Button>



                <!-- Total Tab -->

                <Button Command="{Binding SelectTotalTabCommand}"

                        Margin="2,0">

                    <Button.Style>

                        <Style TargetType="Button" BasedOn="{StaticResource TabPillButtonStyle}">

                            <Style.Triggers>

                                <DataTrigger Binding="{Binding IsTotalTab}" Value="True">

                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>

                                    <Setter Property="Foreground" Value="White"/>

                                </DataTrigger>

                            </Style.Triggers>

                        </Style>

                    </Button.Style>

                    <TextBlock Text="{DynamicResource TotalTabText}"/>

                </Button>



            </StackPanel>

        </Border>



        <!-- Tab Content Area -->

        <Grid Grid.Row="3">



            <!-- ── DAILY TAB ── -->

            <Grid Visibility="{Binding IsDailyTab, Converter={StaticResource BoolToVis}}">

                <ListView ItemsSource="{Binding GroupedTransactions}"

                          Margin="0,0,0,72"

                          Style="{StaticResource TransactionListViewStyle}"

                          ItemTemplate="{StaticResource TransactionItemTemplate}">

                    <ListView.GroupStyle>

                        <GroupStyle ContainerStyle="{StaticResource DailyGroupHeaderStyle}"/>

                    </ListView.GroupStyle>

                </ListView>

            </Grid>



            <!-- ── CALENDAR TAB ── -->

            <Grid Visibility="{Binding IsCalendarTab, Converter={StaticResource BoolToVis}}">

                <Grid.RowDefinitions>

                    <RowDefinition Height="Auto"/>

                    <RowDefinition Height="*"/>

                </Grid.RowDefinitions>



                <Calendar Grid.Row="0"

                          SelectedDate="{Binding SelectedCalendarDate, Mode=TwoWay}"

                          DisplayMode="Month"

                          HorizontalAlignment="Center"

                          Margin="0,0,0,12"/>



                <Grid Grid.Row="1">

                    <ListView ItemsSource="{Binding CalendarTransactions}"

                              Margin="0,0,0,72"

                              Style="{StaticResource TransactionListViewStyle}"

                              ItemTemplate="{StaticResource TransactionItemTemplate}"/>



                    <TextBlock Visibility="{Binding CalendarTransactions.Count,

                                            Converter={StaticResource BoolToVis},

                                            ConverterParameter=inverse}"

                               Text="{DynamicResource NoTransactionsForDayText}"

                               Foreground="{DynamicResource MutedTextBrush}"

                               FontSize="14"

                               HorizontalAlignment="Center"

                               VerticalAlignment="Center">

                        <TextBlock.Style>

                            <Style TargetType="TextBlock">

                                <Setter Property="Visibility" Value="Collapsed"/>

                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding CalendarTransactions.Count}" Value="0">

                                        <Setter Property="Visibility" Value="Visible"/>

                                    </DataTrigger>

                                </Style.Triggers>

                            </Style>

                        </TextBlock.Style>

                    </TextBlock>

                </Grid>

            </Grid>



            <!-- ── MONTHLY TAB ── -->

            <Grid Visibility="{Binding IsMonthlyTab, Converter={StaticResource BoolToVis}}">

                <ListView ItemsSource="{Binding MonthlyGroupedTransactions}"

                          Margin="0,0,0,72"

                          Style="{StaticResource TransactionListViewStyle}"

                          ItemTemplate="{StaticResource TransactionItemTemplate}">

                    <ListView.GroupStyle>

                        <GroupStyle ContainerStyle="{StaticResource GroupHeaderStyle}"/>

                    </ListView.GroupStyle>

                </ListView>

            </Grid>



            <!-- ── TOTAL TAB ── -->

            <Grid Visibility="{Binding IsTotalTab, Converter={StaticResource BoolToVis}}">

                <ListView ItemsSource="{Binding GroupedTransactions}"

                          Margin="0,0,0,72"

                          Style="{StaticResource TransactionListViewStyle}"

                          ItemTemplate="{StaticResource TransactionItemTemplate}">

                    <ListView.GroupStyle>

                        <GroupStyle ContainerStyle="{StaticResource DailyGroupHeaderStyle}"/>

                    </ListView.GroupStyle>

                </ListView>

            </Grid>



            <!-- Floating Add Button -->

            <Button Content="{DynamicResource AddTransactionText}"

                    Command="{Binding AddTransactionCommand}"

                    Style="{StaticResource PrimaryButtonStyle}"

                    HorizontalAlignment="Right"

                    VerticalAlignment="Bottom"

                    Margin="0,0,4,4"

                    Panel.ZIndex="10">

                <Button.Effect>

                    <DropShadowEffect BlurRadius="18" Direction="270" Opacity="0.24"

                                      ShadowDepth="4" Color="#1E3A8A"/>

                </Button.Effect>

            </Button>



        </Grid>

    </Grid>

</UserControl>

