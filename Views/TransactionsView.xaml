<UserControl x:Class="ExpenseTracker.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ExpenseTracker.Converters">
    <UserControl.Resources>
        <converters:EnglishNumberConverter x:Key="EnglishNumberConverter"/>
    </UserControl.Resources>
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="{DynamicResource TransactionsTitle}"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="28"
                           FontWeight="Bold"/>
                <TextBlock Text="{DynamicResource TransactionsSubtitle}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           FontSize="14"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <ListView ItemsSource="{Binding GroupedTransactions}"
                      Margin="0,0,0,78"
                      Padding="0"
                      Background="Transparent"
                      BorderThickness="0"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <StackPanel Margin="0,0,0,18">
                                                <Border Background="{DynamicResource GroupHeaderBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="14,10"
                                                        Margin="0,0,0,10">
                                                    <TextBlock Text="{Binding Name, StringFormat={}{0:dddd, dd MMMM yyyy}}"
                                                               Foreground="{DynamicResource PrimaryBrush}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"/>
                                                </Border>

                                                <ItemsPresenter/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </ListView.GroupStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="16">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14"
                                                  Direction="270"
                                                  Opacity="0.08"
                                                  ShadowDepth="2"
                                                  Color="#0F172A"/>
                            </Border.Effect>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="15"
                                               FontWeight="SemiBold"/>

                                    <StackPanel Margin="0,8,0,0"
                                                Orientation="Horizontal">
                                        <TextBlock Text="{Binding CategoryName}"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   FontSize="13"/>
                                        <TextBlock Text="  •  "
                                                   Foreground="{DynamicResource BorderBrush}"
                                                   FontSize="13"/>
                                        <TextBlock Text="{Binding AccountName}"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Background="{DynamicResource SurfaceAltBrush}"
                                        CornerRadius="10"
                                        Padding="12,8"
                                        VerticalAlignment="Center"
                                        Margin="20,0,0,0">
                                    <TextBlock Text="{Binding Amount, Converter={StaticResource EnglishNumberConverter}, ConverterParameter=N2}"
                                               Foreground="{DynamicResource SuccessBrush}"
                                               FontSize="16"
                                               FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Content="{DynamicResource AddTransactionText}"
                    Command="{Binding AddTransactionCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,4,4">
                <Button.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      Direction="270"
                                      Opacity="0.24"
                                      ShadowDepth="4"
                                      Color="#1E3A8A"/>
                </Button.Effect>
            </Button>
        </Grid>
    </Grid>
</UserControl>
