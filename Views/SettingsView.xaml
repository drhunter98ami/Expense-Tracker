<UserControl x:Class="ExpenseTracker.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ExpenseTracker.Converters">
    <UserControl.Resources>
        <converters:EnglishNumberConverter x:Key="EnglishNumberConverter"/>
        
        <!-- Drop Shadow Effect -->
        <DropShadowEffect x:Key="CardShadow"
                          Color="#1F2937"
                          Opacity="0.12"
                          BlurRadius="20"
                          ShadowDepth="4"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Background="{DynamicResource AppBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="{DynamicResource SettingsTitle}"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="32" FontWeight="Bold"/>
                <TextBlock Text="{DynamicResource SettingsSubtitle}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           FontSize="15" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Income Categories -->
            <Border Grid.Row="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="28"
                    Margin="0,0,0,24"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource IncomeCategoriesTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="22" FontWeight="SemiBold"
                               Margin="0,0,0,18"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewIncomeCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="16,14" FontSize="15"
                                 Background="{DynamicResource SurfaceAltBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="14"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <Button Grid.Column="1"
                                Content="{DynamicResource AddCategoryText}"
                                Command="{Binding AddIncomeCategoryCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="14,0,0,0"
                                Padding="28,14"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding IncomeCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="20,16"
                                        Margin="0,0,0,12"
                                        Effect="{StaticResource CardShadow}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>
                                        <ItemsControl ItemsSource="{Binding SubCategories}" Margin="0,12,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="12"
                                                            Padding="14,12"
                                                            Margin="0,0,0,8">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#2D3A4E"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{DynamicResource TextBrush}"
                                                                   FontSize="14"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Expense Categories -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="28"
                    Margin="0,0,0,24"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource ExpenseCategoriesTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="22" FontWeight="SemiBold"
                               Margin="0,0,0,18"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewExpenseCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="16,14" FontSize="15"
                                 Background="{DynamicResource SurfaceAltBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="14"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <Button Grid.Column="1"
                                Content="{DynamicResource AddCategoryText}"
                                Command="{Binding AddExpenseCategoryCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="14,0,0,0"
                                Padding="28,14"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding ExpenseCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="20,16"
                                        Margin="0,0,0,12"
                                        Effect="{StaticResource CardShadow}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>
                                        <ItemsControl ItemsSource="{Binding SubCategories}" Margin="0,12,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource SurfaceAltBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="12"
                                                            Padding="14,12"
                                                            Margin="0,0,0,8">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#2D3A4E"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{DynamicResource TextBrush}"
                                                                   FontSize="14"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Add Sub Category -->
            <Border Grid.Row="3"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="28"
                    Margin="0,0,0,24"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="إضافة تصنيف فرعي"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="22" FontWeight="SemiBold"
                               Margin="0,0,0,18"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ParentCategoryComboBox"
                                  ItemsSource="{Binding AllParentCategories}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedParentCategoryId}"
                                  Padding="16,14" FontSize="15"
                                  Background="{DynamicResource SurfaceAltBrush}"
                                  Foreground="{DynamicResource TextBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  BorderThickness="1"
                                  Grid.Row="0"
                                  Margin="0,0,0,14">
                            <ComboBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="14"/>
                                </Style>
                            </ComboBox.Resources>
                        </ComboBox>
                        <TextBox Text="{Binding NewSubCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="16,14" FontSize="15"
                                 Background="{DynamicResource SurfaceAltBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"
                                 Grid.Row="1">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="14"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <Button Grid.Row="1" Grid.Column="1"
                                Content="إضافة"
                                Command="{Binding AddSubCategoryCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="14,0,0,0"
                                Padding="28,14"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Currency -->
            <Border Grid.Row="4"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="28"
                    Margin="0,0,0,24"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource CurrencySectionTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="22" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="{DynamicResource CurrencySectionSubtitle}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="15" TextWrapping="Wrap"
                               Margin="0,0,0,24"/>

                    <!-- SYP / USD pill toggle -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="7">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- SYP button -->
                            <Button Grid.Column="0"
                                    Content="{DynamicResource SypCurrencyLabel}"
                                    Command="{Binding SelectSypCommand}"
                                    FontSize="15" FontWeight="SemiBold"
                                    Padding="0,14"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                                Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsUsd}" Value="False">
                                                <Setter TargetName="Bg" Property="Background"
                                                        Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUsd}" Value="False">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- USD button -->
                            <Button Grid.Column="1"
                                    Content="{DynamicResource UsdCurrencyLabel}"
                                    Command="{Binding SelectUsdCommand}"
                                    FontSize="15" FontWeight="SemiBold"
                                    Padding="0,14"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                                Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsUsd}" Value="True">
                                                <Setter TargetName="Bg" Property="Background"
                                                        Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUsd}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Exchange Rate -->
            <Border Grid.Row="5"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="28"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource ExchangeRateTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="22" FontWeight="SemiBold"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="{DynamicResource ExchangeRateSubtitle}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="15" TextWrapping="Wrap"
                               Margin="0,0,0,20"/>
                    <TextBlock Text="{DynamicResource UsdToSypRateLabel}"
                               Foreground="{DynamicResource TextBrush}"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Margin="0,0,0,14"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding UsdToSypRateText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="16,14" FontSize="15"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 BorderThickness="1"
                                 Language="en-US"
                                 FlowDirection="LeftToRight"
                                 TextAlignment="Left">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="14"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <Button Grid.Column="1"
                                Content="{DynamicResource SaveText}"
                                Command="{Binding SaveExchangeRateCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="14,0,0,0"
                                Padding="28,14"/>
                    </Grid>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
