<UserControl x:Class="ExpenseTracker.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ExpenseTracker.Converters">
    <UserControl.Resources>
        <converters:EnglishNumberConverter x:Key="EnglishNumberConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Background="{DynamicResource AppBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Margin="0,0,0,22">
                <TextBlock Text="{DynamicResource SettingsTitle}"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="{DynamicResource SettingsSubtitle}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           FontSize="14" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Income Categories -->
            <Border Grid.Row="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource IncomeCategoriesTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewIncomeCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="11,9" FontSize="14"
                                 Background="{DynamicResource SurfaceAltBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                        <Button Grid.Column="1"
                                Content="{DynamicResource AddCategoryText}"
                                Command="{Binding AddIncomeCategoryCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="10,0,0,0"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding IncomeCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12,10"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"/>
                                        <ItemsControl ItemsSource="{Binding SubCategories}" Margin="0,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource AppBackgroundBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Padding="10,8"
                                                            Margin="0,0,0,6">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{DynamicResource TextBrush}"
                                                                   FontSize="13"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Expense Categories -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource ExpenseCategoriesTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewExpenseCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="11,9" FontSize="14"
                                 Background="{DynamicResource SurfaceAltBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                        <Button Grid.Column="1"
                                Content="{DynamicResource AddCategoryText}"
                                Command="{Binding AddExpenseCategoryCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="10,0,0,0"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding ExpenseCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceAltBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12,10"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"/>
                                        <ItemsControl ItemsSource="{Binding SubCategories}" Margin="0,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource AppBackgroundBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Padding="10,8"
                                                            Margin="0,0,0,6">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="{DynamicResource TextBrush}"
                                                                   FontSize="13"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Add Sub Category -->
            <Border Grid.Row="3"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="إضافة تصنيف فرعي"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ParentCategoryComboBox"
                                  ItemsSource="{Binding AllParentCategories}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedParentCategoryId}"
                                  Padding="11,9" FontSize="14"
                                  Background="{DynamicResource SurfaceAltBrush}"
                                  Foreground="{DynamicResource TextBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}"
                                  Grid.Row="0"
                                  Margin="0,0,0,10"/>
                        <TextBox Text="{Binding NewSubCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="11,9" FontSize="14"
                                 Background="{DynamicResource SurfaceAltBrush}"
                                 Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"
                                 Grid.Row="1"/>
                        <Button Grid.Row="1" Grid.Column="1"
                                Content="إضافة"
                                Command="{Binding AddSubCategoryCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Currency -->
            <Border Grid.Row="4"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="20"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{DynamicResource CurrencySectionTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{DynamicResource CurrencySectionSubtitle}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="13" TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <!-- SYP / USD pill toggle -->
                    <Border Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- SYP button -->
                            <Button Grid.Column="0"
                                    Content="{DynamicResource SypCurrencyLabel}"
                                    Command="{Binding SelectSypCommand}"
                                    FontSize="14" FontWeight="SemiBold"
                                    Padding="0,10"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" CornerRadius="10" Padding="{TemplateBinding Padding}"
                                                Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsUsd}" Value="False">
                                                <Setter TargetName="Bg" Property="Background"
                                                        Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUsd}" Value="False">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <!-- USD button -->
                            <Button Grid.Column="1"
                                    Content="{DynamicResource UsdCurrencyLabel}"
                                    Command="{Binding SelectUsdCommand}"
                                    FontSize="14" FontWeight="SemiBold"
                                    Padding="0,10"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" CornerRadius="10" Padding="{TemplateBinding Padding}"
                                                Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsUsd}" Value="True">
                                                <Setter TargetName="Bg" Property="Background"
                                                        Value="{DynamicResource PrimaryBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUsd}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Exchange Rate -->
            <Border Grid.Row="5"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="{DynamicResource ExchangeRateTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="18" FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{DynamicResource ExchangeRateSubtitle}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="13" TextWrapping="Wrap"
                               Margin="0,0,0,14"/>
                    <TextBlock Text="{DynamicResource UsdToSypRateLabel}"
                               Foreground="{DynamicResource TextBrush}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding UsdToSypRateText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource NumberTextBoxStyle}"/>
                        <Button Grid.Column="1"
                                Content="{DynamicResource SaveText}"
                                Command="{Binding SaveExchangeRateCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</UserControl>
