<UserControl x:Class="ExpenseTracker.Views.AccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ExpenseTracker.Converters">
    <UserControl.Resources>
        <converters:EnglishNumberConverter x:Key="EnglishNumberConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{DynamicResource AccountsTitle}"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="{DynamicResource AccountsSubtitle}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           FontSize="14" Margin="0,6,0,0"/>
            </StackPanel>
            <Button Content="{DynamicResource AddAccountText}"
                    Command="{Binding AddAccountCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- Total Assets Card -->
        <Border Grid.Row="1"
                Background="{DynamicResource PrimaryBrush}"
                CornerRadius="18"
                Padding="24"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{DynamicResource TotalAssetsLabel}"
                               Foreground="{DynamicResource OnPrimaryBrush}"
                               FontSize="15" FontWeight="SemiBold" Opacity="0.85"/>
                    <TextBlock Text="{Binding TotalAssets, Converter={StaticResource EnglishNumberConverter}, ConverterParameter=N2}"
                               Foreground="{DynamicResource OnPrimaryBrush}"
                               FontSize="36" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Width="58" Height="58"
                        Background="#33FFFFFF"
                        CornerRadius="18"
                        VerticalAlignment="Center">
                    <TextBlock Text="💰" FontSize="26"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Account Groups -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding AccountGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Margin="0,0,0,14">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14" Direction="270"
                                                  Opacity="0.07" ShadowDepth="2"
                                                  Color="#0F172A"/>
                            </Border.Effect>
                            <StackPanel>

                                <!-- Group Header -->
                                <Border Background="{DynamicResource GroupHeaderBrush}"
                                        CornerRadius="16,16,0,0"
                                        Padding="18,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding GroupDisplayName}"
                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                   FontSize="15" FontWeight="Bold"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="{DynamicResource GroupTotalLabel}"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding GroupTotal, Converter={StaticResource EnglishNumberConverter}, ConverterParameter=N2}"
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       FontSize="15" FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Account Rows -->
                                <ItemsControl ItemsSource="{Binding Accounts}" Margin="0,4,0,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="18,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="15" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{DynamicResource CurrentBalanceLabel}"
                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                               FontSize="12" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        CornerRadius="10"
                                                        Padding="14,8"
                                                        VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#F0FDF4"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Balance}" Value="0">
                                                                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Balance, Converter={StaticResource EnglishNumberConverter}, ConverterParameter=N2}"
                                                               FontSize="16" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#16A34A"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Balance}" Value="0">
                                                                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
