<Window x:Class="ExpenseTracker.Views.AddAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AddAccountDialogTitle}"
        Width="440"
        Height="510"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="DialogLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource AppBackgroundBrush}" Padding="22">
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="{DynamicResource AddAccountDialogTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="24" FontWeight="Bold"/>
                    <Border Width="52" Height="4"
                            HorizontalAlignment="Right"
                            Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="2" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Form -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,0,4,0">
                    <StackPanel>

                        <!-- Account Name -->
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="{DynamicResource AccountNameLabel}"
                                       Style="{StaticResource DialogLabelStyle}"/>
                            <TextBox x:Name="AccountNameTextBox"
                                     Padding="11,9" FontSize="14"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource TextBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"/>
                        </StackPanel>

                        <!-- Account Group -->
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="{DynamicResource AccountGroupLabel}"
                                       Style="{StaticResource DialogLabelStyle}"/>
                            <ComboBox x:Name="AccountGroupComboBox"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Key"
                                      Padding="9" FontSize="14"
                                      Background="{DynamicResource SurfaceBrush}"
                                      Foreground="{DynamicResource TextBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      MinHeight="40"/>
                            <!-- Add new custom category -->
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="10"
                                    Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NewCategoryTextBox"
                                             Grid.Column="0"
                                             Padding="8,7" FontSize="13"
                                             Background="{DynamicResource SurfaceBrush}"
                                             Foreground="{DynamicResource TextBrush}"
                                             BorderBrush="{DynamicResource BorderBrush}"
                                             BorderThickness="1"/>
                                    <Button Grid.Column="2"
                                            Content="{DynamicResource AddCategoryText}"
                                            Click="AddCategoryButton_Click"
                                            Padding="14,7" FontSize="13"
                                            FontWeight="SemiBold"
                                            Cursor="Hand"
                                            Background="{DynamicResource PrimaryBrush}"
                                            Foreground="White"
                                            BorderThickness="0"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Account Currency -->
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="{DynamicResource AccountCurrencyLabel}"
                                       Style="{StaticResource DialogLabelStyle}"/>
                            <Border Background="{DynamicResource SurfaceAltBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="SypButton"
                                            Grid.Column="0"
                                            Content="ل.س  SYP"
                                            Click="SypButton_Click"
                                            FontSize="13" FontWeight="SemiBold"
                                            Padding="0,9"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="9"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="UsdButton"
                                            Grid.Column="1"
                                            Content="$  USD"
                                            Click="UsdButton_Click"
                                            FontSize="13" FontWeight="SemiBold"
                                            Padding="0,9"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bg"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="9"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Opening Balance -->
                        <StackPanel>
                            <TextBlock Text="{DynamicResource InitialBalanceLabel}"
                                       Style="{StaticResource DialogLabelStyle}"/>
                            <TextBox x:Name="InitialBalanceTextBox"
                                     Style="{StaticResource NumberTextBoxStyle}"
                                     TextChanged="InitialBalanceTextBox_TextChanged"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Buttons -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0,18,0,0">
                    <Button Content="{DynamicResource SaveText}"
                            Click="SaveButton_Click"
                            Width="100"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Content="{DynamicResource CancelText}"
                            Click="CancelButton_Click"
                            Width="100" Padding="12,8"
                            Margin="10,0,0,0"
                            Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
