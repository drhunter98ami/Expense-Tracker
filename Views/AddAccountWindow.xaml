<Window x:Class="ExpenseTracker.Views.AddAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource AddAccountDialogTitle}"
        Width="440"
        Height="530"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="DialogLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="DialogTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="11,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DialogComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource AppBackgroundBrush}" Padding="22">
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Dialog Title -->
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="{DynamicResource AddAccountDialogTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="24"
                               FontWeight="Bold"/>
                    <Border Width="52" Height="4"
                            HorizontalAlignment="Right"
                            Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="2"
                            Margin="0,10,0,0"/>
                </StackPanel>

                <!-- Form Fields -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,0,4,0">
                    <StackPanel>

                        <!-- Account Name -->
                        <StackPanel>
                            <TextBlock Text="{DynamicResource AccountNameLabel}"
                                       Style="{StaticResource DialogLabelStyle}"/>
                            <TextBox x:Name="AccountNameTextBox"
                                     Style="{StaticResource DialogTextBoxStyle}"/>
                        </StackPanel>

                        <!-- Account Group -->
                        <StackPanel Margin="0,13,0,0">
                            <TextBlock Text="{DynamicResource AccountGroupLabel}"
                                       Style="{StaticResource DialogLabelStyle}"/>
                            <ComboBox x:Name="AccountGroupComboBox"
                                      IsEditable="True"
                                      Style="{StaticResource DialogComboBoxStyle}"
                                      MinHeight="40"/>
                            <TextBlock Text="{DynamicResource AccountGroupHint}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="12"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Initial Balance -->
                        <StackPanel Margin="0,13,0,0">
                            <TextBlock Text="{DynamicResource InitialBalanceLabel}"
                                       Style="{StaticResource DialogLabelStyle}"/>
                            <TextBox x:Name="InitialBalanceTextBox"
                                     Style="{StaticResource NumberTextBoxStyle}"
                                     TextChanged="InitialBalanceTextBox_TextChanged"/>
                        </StackPanel>

                        <!-- Income Category (only relevant when balance > 0) -->
                        <StackPanel Margin="0,13,0,0">
                            <TextBlock Text="{DynamicResource CategoryLabel}"
                                       Style="{StaticResource DialogLabelStyle}"/>
                            <ComboBox x:Name="CategoryComboBox"
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Id"
                                      Style="{StaticResource DialogComboBoxStyle}"
                                      MinHeight="40"/>
                            <TextBlock Text="{DynamicResource InitialBalanceCategoryHint}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="12"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Buttons -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0,18,0,0">
                    <Button Content="{DynamicResource SaveText}"
                            Click="SaveButton_Click"
                            Width="100"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Content="{DynamicResource CancelText}"
                            Click="CancelButton_Click"
                            Width="100"
                            Padding="12,8"
                            Margin="10,0,0,0"
                            Background="{DynamicResource SurfaceAltBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            Foreground="{DynamicResource TextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
